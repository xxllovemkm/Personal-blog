---
import Page from '../layouts/Page.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import avatar from '../assets/images/avatar.webp';
import { getPublications, openReviewProfile } from '../data/publications';
import { postPath, sitePath } from '../utils';

const featuredPublicationTitles = new Set([
  'GGBench: A Geometric Generative Reasoning Benchmark for Unified Multimodal Models',
  'Programming with Data: Test-Driven Data Engineering for Self-Improving LLMs from Raw Corpora',
  'PaperFit: Vision-in-the-Loop Typesetting Optimization for Scientific Documents',
]);

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const projects = await getCollection('projects');
const publications = await getPublications();
const featuredProjects = projects.slice(0, 5);
const featuredPublications = publications.filter((paper) => featuredPublicationTitles.has(paper.title));
const projectUrl = (project: typeof projects[number]) => project.data.demo || project.data.repo;
---

<Page title="许兴龙 - 个人博客">
  <section class="grid md:grid-cols-3 gap-8">
    <!-- 个人信息 -->
    <aside class="md:col-span-1">
      <div class="card text-center">
        <div class="w-24 h-24 mx-auto mb-4 rounded-full overflow-hidden border border-smoke dark:border-dark-border bg-smoke dark:bg-dark-border">
          <Image
            src={avatar}
            alt="许兴龙"
            width={192}
            height={192}
            class="w-full h-full object-cover"
          />
        </div>
        <h1 class="text-lg font-heading mb-1">许兴龙</h1>
        <p class="text-sm text-ink-light dark:text-dark-text-secondary mb-4">
          中国科学院大学计算机技术硕士，研究方向为 GUI agent 和多模态推理。
        </p>
        <div class="flex justify-center gap-3 text-ink-light dark:text-dark-text-secondary">
          <a href="https://github.com/xxllovemkm" aria-label="GitHub" class="hover:text-cyan-dark dark:hover:text-cyan-light">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .5C5.37.5 0 5.78 0 12.292c0 5.211 3.438 9.63 8.205 11.188.6.111.82-.254.82-.567 0-.28-.01-1.022-.015-2.005-3.338.711-4.042-1.582-4.042-1.582-.546-1.361-1.333-1.723-1.333-1.723-1.089-.731.083-.716.083-.716 1.205.082 1.838 1.215 1.838 1.215 1.07 1.802 2.807 1.281 3.492.98.108-.762.418-1.281.762-1.576-2.665-.297-5.466-1.309-5.466-5.827 0-1.287.465-2.339 1.228-3.164-.122-.298-.532-1.497.117-3.12 0 0 1.001-.314 3.28 1.209A11.5 11.5 0 0112 6.844c1.02.005 2.047.135 3.004.397 2.277-1.523 3.275-1.209 3.275-1.209.651 1.623.241 2.822.118 3.12.765.825 1.226 1.877 1.226 3.164 0 4.53-2.805 5.527-5.475 5.818.43.365.814 1.084.814 2.184 0 1.576-.014 2.846-.014 3.232 0 .316.216.683.825.567C20.565 21.917 24 17.5 24 12.292 24 5.78 18.627.5 12 .5z"/></svg>
          </a>
          <a href="mailto:xuxinglong00423@163.com" aria-label="邮箱" class="hover:text-cyan-dark dark:hover:text-cyan-light">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </a>
          <a href={openReviewProfile} aria-label="OpenReview" class="text-sm font-mono no-underline hover:text-cyan-dark dark:hover:text-cyan-light">
            OR
          </a>
        </div>
      </div>

      <!-- 站点统计 -->
      <div class="card mt-4">
        <div class="grid grid-cols-3 gap-3 text-center text-sm">
          <div>
            <div class="text-lg font-heading text-cyan-dark dark:text-cyan-light">{posts.length}</div>
            <div class="text-ink-light dark:text-dark-text-secondary">文章</div>
          </div>
          <div>
            <div class="text-lg font-heading text-cyan-dark dark:text-cyan-light">{projects.length}</div>
            <div class="text-ink-light dark:text-dark-text-secondary">项目</div>
          </div>
          <div>
            <div class="text-lg font-heading text-cyan-dark dark:text-cyan-light">{publications.length}</div>
            <div class="text-ink-light dark:text-dark-text-secondary">论文</div>
          </div>
        </div>
      </div>

      <div class="card mt-4">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-base font-heading">发表论文</h2>
          <a href={sitePath('/publications')} class="text-xs no-underline text-ink-light dark:text-dark-text-secondary hover:text-cyan-dark dark:hover:text-cyan-light">
            全部 &rarr;
          </a>
        </div>
        <div class="space-y-3">
          {featuredPublications.map((paper) => (
            <article>
              <a
                href={paper.url}
                class="font-heading text-sm leading-relaxed text-ink dark:text-dark-text no-underline hover:text-cyan-dark dark:hover:text-cyan-light"
              >
                {paper.title}
              </a>
              {(paper.venue || paper.status || paper.rank) && (
                <div class="mt-1 flex flex-wrap gap-2 text-xs text-ink-light dark:text-dark-text-secondary">
                  {paper.venue && <span>{paper.venue}</span>}
                  {paper.status && <span>{paper.status}</span>}
                  {paper.rank && <span>{paper.rank}</span>}
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </aside>

    <!-- 主内容区 -->
    <div class="md:col-span-2 space-y-8">
      <!-- 最新文章 -->
      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-heading">最新文章</h2>
          <a href={sitePath('/posts')} class="text-sm text-ink-light dark:text-dark-text-secondary no-underline hover:text-cyan-dark">
            全部 &rarr;
          </a>
        </div>
        {posts.length > 0 ? (
          <div class="space-y-3">
            {posts.map((post) => (
              <a href={postPath(post.id)} class="card block no-underline group">
                <h3 class="font-heading text-ink dark:text-dark-text group-hover:text-cyan-dark dark:group-hover:text-cyan-light transition-colors">
                  {post.data.title}
                </h3>
                <div class="flex items-center gap-2 mt-2 text-sm text-ink-light dark:text-dark-text-secondary">
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('zh-CN')}
                  </time>
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                {post.data.summary && (
                  <p class="mt-2 text-sm text-ink-light dark:text-dark-text-secondary line-clamp-2">
                    {post.data.summary}
                  </p>
                )}
              </a>
            ))}
          </div>
        ) : (
          <p class="text-ink-light dark:text-dark-text-secondary text-sm">暂无文章</p>
        )}
      </section>

      <!-- 项目 -->
      {projects.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-heading">项目</h2>
            <a href={sitePath('/projects')} class="text-sm text-ink-light dark:text-dark-text-secondary no-underline hover:text-cyan-dark">
              全部 &rarr;
            </a>
          </div>
          <div class="grid gap-3">
            {featuredProjects.map((project) => (
              <div class="card">
                <h3 class="font-heading">
                  {projectUrl(project) ? (
                    <a href={projectUrl(project)} class="text-ink dark:text-dark-text no-underline hover:text-cyan-dark dark:hover:text-cyan-light">
                      {project.data.title}
                    </a>
                  ) : (
                    project.data.title
                  )}
                </h3>
                {project.data.summary && (
                  <p class="mt-1 text-sm text-ink-light dark:text-dark-text-secondary">{project.data.summary}</p>
                )}
              </div>
            ))}
          </div>
        </section>
      )}
    </div>
  </section>
</Page>
