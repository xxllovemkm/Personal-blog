---
import Page from '../../layouts/Page.astro';
import { Image } from 'astro:assets';
import avatar from '../../assets/images/avatar.webp';
import { getPublications, openReviewProfile } from '../../data/publications';

const publications = await getPublications();
---

<Page title="关于 - 许兴龙">
  <div class="grid md:grid-cols-[180px_1fr] gap-8 items-start">
    <aside class="card text-center">
      <div class="w-28 h-28 mx-auto mb-4 rounded-full overflow-hidden border border-smoke dark:border-dark-border bg-smoke dark:bg-dark-border">
        <Image
          src={avatar}
          alt="许兴龙"
          width={224}
          height={224}
          class="w-full h-full object-cover"
        />
      </div>
      <h1 class="text-xl font-heading mb-2">许兴龙</h1>
      <p class="text-sm text-ink-light dark:text-dark-text-secondary">
        GUI agent / 多模态推理
      </p>
    </aside>

    <div class="max-w-prose space-y-8 text-ink dark:text-dark-text">
      <section class="space-y-4">
        <h2 class="text-lg font-heading">关于我</h2>
        <p>
          我是许兴龙，中国科学院大学计算机技术硕士，研究方向为 GUI agent 和多模态推理。
        </p>
        <p>
          近期工作关注多模态模型在几何构造、图形界面控制、跨模态生成推理和复杂视觉任务中的精确性、可验证性与闭环优化。
        </p>
      </section>

      <section class="space-y-3">
        <h2 class="text-lg font-heading">教育背景</h2>
        <div class="space-y-2 text-sm">
          <p>2019 - 2024：山东科技大学，计算机科学与技术，本科</p>
          <p>2025 - 至今：中国科学院大学，计算机技术，硕士研究生</p>
        </div>
      </section>

      <section class="space-y-3">
        <h2 class="text-lg font-heading">科研方向</h2>
        <ul class="list-disc pl-5 space-y-2 text-sm">
          <li>GUI agent：点精度操作、几何构造、界面规划与执行闭环。</li>
          <li>多模态推理：跨模态一致性、交错式文本-视觉推理与可验证评测。</li>
        </ul>
      </section>

      <section class="space-y-3">
        <h2 class="text-lg font-heading">代表工作</h2>
        <div class="space-y-3 text-sm">
          {publications.map((paper) => (
            <article>
              <a
                href={paper.url}
                class="font-heading text-ink dark:text-dark-text no-underline hover:text-cyan-dark dark:hover:text-cyan-light"
              >
                {paper.title}
              </a>
            </article>
          ))}
        </div>
      </section>

      <section class="space-y-3">
        <h2 class="text-lg font-heading">联系方式</h2>
        <ul class="space-y-1 text-sm">
          <li>GitHub：<a href="https://github.com/xxllovemkm">@xxllovemkm</a></li>
          <li>OpenReview：<a href={openReviewProfile}>Xinglong Xu</a></li>
          <li>邮箱：<a href="mailto:xuxinglong00423@163.com">xuxinglong00423@163.com</a></li>
        </ul>
      </section>
    </div>
  </div>
</Page>
