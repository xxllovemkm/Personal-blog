---
import { sitePath } from '../utils';

const navItems = [
  { path: '/', label: '首页' },
  { path: '/posts', label: '文章' },
  { path: '/archive', label: '归档' },
  { path: '/tags', label: '标签' },
  { path: '/publications', label: '论文' },
  { path: '/projects', label: '项目' },
  { path: '/about', label: '关于' },
];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.startsWith(base)
  ? Astro.url.pathname.slice(base.length) || '/'
  : Astro.url.pathname;
---

<header class="border-b border-smoke dark:border-dark-border">
  <nav class="max-w-4xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href={sitePath('/')} class="font-heading text-lg text-ink dark:text-dark-text no-underline shrink-0">
      许兴龙
    </a>
    <div class="hidden md:flex items-center gap-6">
      {navItems.map((item) => (
        <a
          href={sitePath(item.path)}
          class:list={[
            'text-sm no-underline transition-colors',
            currentPath === item.path || (item.path !== '/' && currentPath.startsWith(item.path))
              ? 'text-cyan-dark dark:text-cyan-light'
              : 'text-ink-light dark:text-dark-text-secondary hover:text-cyan-dark dark:hover:text-cyan-light',
          ]}
        >
          {item.label}
        </a>
      ))}
      <button
        id="theme-toggle"
        class="text-ink-light dark:text-dark-text-secondary hover:text-cyan-dark dark:hover:text-cyan-light"
        aria-label="切换深色模式"
      >
        <svg class="w-4 h-4 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
        </svg>
        <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="5" stroke-width="1.5" />
          <path stroke-linecap="round" stroke-width="1.5" d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
      </button>
    </div>
    <!-- 移动端菜单按钮 -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-ink-light dark:text-dark-text-secondary"
      aria-label="菜单"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
  <!-- 移动端导航面板 -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-smoke dark:border-dark-border px-4 py-3">
    <div class="flex flex-wrap gap-x-4 gap-y-2">
      {navItems.map((item) => (
        <a
          href={sitePath(item.path)}
          class:list={[
            'text-sm no-underline',
            currentPath === item.path || (item.path !== '/' && currentPath.startsWith(item.path))
              ? 'text-cyan-dark dark:text-cyan-light'
              : 'text-ink-light dark:text-dark-text-secondary',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
    <button
      id="theme-toggle-mobile"
      class="mt-2 text-sm text-ink-light dark:text-dark-text-secondary"
    >
      切换深色模式
    </button>
  </div>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');
  const toggleMobile = document.getElementById('theme-toggle-mobile');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  function switchTheme() {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  }

  toggle?.addEventListener('click', switchTheme);
  toggleMobile?.addEventListener('click', switchTheme);
  menuBtn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
